{% extends 'base-uboot.jinja2' %}
{% set bootloader_prompt = bootloader_prompt|default('ZynqMP>') %}
{% set bootm_kernel_addr = '0x10000000' %}
{% set bootm_ramdisk_addr = '0x18000000' %}
{% set bootm_dtb_addr = '0x1c000000' %}
{% set base_ip_args = 'ip=dhcp' %}
{% set uboot_mkimage_arch = 'arm64' %}
{% set uboot_tftp_commands = [
    "tftpboot {KERNEL_ADDR} {KERNEL}",
    "tftpboot {RAMDISK_ADDR} {RAMDISK}",
    "tftpboot {DTB_ADDR} {DTB}"]
-%}
{% set console_device = 'ttyPS0' %}
{% set baud_rate = '115200' %}
