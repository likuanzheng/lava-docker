# AUTO-GENERATED by gen-jobs.py from job-templates/{{ device_type }}/backup.yaml.j2 — DO NOT EDIT
device_type: {{ device_type }}
job_name: {{ name }} backup nvme to server
{% if tags %}tags:
{% for t in tags %}  - {{ t }}
{% endfor %}{% endif %}
# 备份流程：
#   1. U-Boot 通过 TFTP 加载 initramfs 并 booti 启动
#   2. 登录 initramfs Linux（openEuler Embedded）
#   3. dd 读取 /dev/nvme0n1，通过 SSH 推送到服务器

timeouts:
  job:
    minutes: {{ timeouts.job }}
  action:
    minutes: {{ timeouts.action }}

priority: medium
visibility: public

actions:
- boot:
    method: u-boot
    commands: []
    timeout:
      minutes: 2

- test:
    timeout:
      minutes: {{ timeouts.test }}
    interactive:
    - name: uboot-tftp-boot
      prompts: ['D2000#']
      script:
      - command: null
        name: wait-prompt

      - command: "setenv ethact {{ ethact }}; setenv ipaddr {{ boot_ipaddr }}; setenv serverip {{ serverip }}; setenv netmask {{ netmask }}; setenv gatewayip {{ gatewayip }}; tftpboot 0x80500000 tftp/{{ device_type }}/Image"
        name: tftp-kernel
        wait_for_prompt: false
        successes:
        - message: "Bytes transferred"
        failures:
        - message: "TFTP error"
          exception: JobError
          error: "Failed to download Image"
        - message: "File not found"
          exception: JobError
          error: "Image not found on TFTP server"

      - command: null
        name: wait-after-tftp-kernel

      - command: "tftpboot 0x88500000 tftp/{{ device_type }}/d2000-devboard-dsk-fixed.dtb"
        name: tftp-dtb
        wait_for_prompt: false
        successes:
        - message: "Bytes transferred"
        failures:
        - message: "TFTP error"
          exception: JobError
          error: "Failed to download dtb"
        - message: "File not found"
          exception: JobError
          error: "dtb not found on TFTP server"

      - command: null
        name: wait-after-tftp-dtb

      - command: "tftpboot 0x89500000 tftp/{{ device_type }}/uInitrd"
        name: tftp-ramdisk
        wait_for_prompt: false
        successes:
        - message: "Bytes transferred"
        failures:
        - message: "TFTP error"
          exception: JobError
          error: "Failed to download uInitrd"
        - message: "File not found"
          exception: JobError
          error: "uInitrd not found on TFTP server"

      - command: null
        name: wait-after-tftp-ramdisk

      - command: "booti 0x80500000 0x89500000:${filesize} 0x88500000"
        name: booti
        wait_for_prompt: false
        successes:
        - message: "System booting cost"
        failures:
        - message: "Wrong Image Format"
          exception: JobError
          error: "Kernel image corrupted"
        - message: "Bad Linux ARM64 Image magic"
          exception: JobError
          error: "Invalid kernel image"

    - name: linux-login
      prompts: ['phytium login:', '# ']
      script:
      - command: null
        name: wait-login-prompt
      - command: "root"
        name: login
        wait_for_prompt: false
      - command: ""
        name: enter-1
        wait_for_prompt: false
      - command: ""
        name: enter-2
      - command: null
        name: wait-shell

    - name: backup-nvme
      prompts: ['LAVA_NEVER_MATCH_XYZ']
      script:
      - command: "{{ net_setup }}; curl -f http://{{ serverip }}/tmp/tftp/{{ device_type }}/backup.sh | sh"
        name: backup-nvme
        wait_for_prompt: false
        successes:
        - message: "backup_ok"
        failures:
        - message: "ssh: "
          exception: JobError
          error: "SSH connection to server failed"
        - message: "dd: error"
          exception: JobError
          error: "Failed to read nvme0n1"
        - message: "Permission denied"
          exception: JobError
          error: "SSH authentication failed"
        - message: "curl: "
          exception: JobError
          error: "Failed to download backup script"

- command:
    name: hard_reset
    timeout:
      minutes: 1
