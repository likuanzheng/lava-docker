#!/bin/sh
# AUTO-GENERATED by gen-jobs.py from job-templates/{{ device_type }}/backup.sh.j2 — DO NOT EDIT
# 在设备的 RAM 系统里运行：dd 取 nvme 整盘 → ssh 推回服务器的 _backup/{{ device_type }}/。
# 从服务器同步时间（设备无 RTC，避免备份文件名时间戳错乱）
TS=$(ssh -F /dev/null -o StrictHostKeyChecking=no -o Ciphers=aes128-ctr -i /root/.ssh/id_ed25519 {{ ssh_user }}@{{ serverip }} date +%s)
[ -n "$TS" ] && date -s @$TS
FNAME="XZZJ-A100-backup-$(date +%Y%m%d-%H%M%S).img"
# 落点是部署机上仓库 checkout 的绝对路径（= tftp bind-mount 源）；按部署机实际 checkout 改。
dd if=/dev/nvme0n1 bs=4M status=progress | ssh -F /dev/null -o StrictHostKeyChecking=no -o Ciphers=aes128-ctr -i /root/.ssh/id_ed25519 {{ ssh_user }}@{{ serverip }} "dd of=/home/ywyh/dev/lava-docker/user-data/tftp/_backup/{{ device_type }}/$FNAME bs=4M"
echo backup_ok
