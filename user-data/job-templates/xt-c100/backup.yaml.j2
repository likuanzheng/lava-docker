# AUTO-GENERATED by gen-jobs.py from job-templates/{{ device_type }}/backup.yaml.j2 — DO NOT EDIT
device_type: {{ device_type }}
job_name: {{ name }} backup kernel and rootfs to TFTP
{% if tags %}tags:
{% for t in tags %}  - {{ t }}
{% endfor %}{% endif %}
# kernel 分区: offset {{ partitions.kernel.offset }}, size {{ partitions.kernel.size }}
# rootfs 分区: offset {{ partitions.rootfs.offset }}, read {{ partitions.rootfs.read }}

timeouts:
  job:
    minutes: {{ timeouts.job }}
  action:
    minutes: {{ timeouts.action }}

priority: medium
visibility: public

actions:
- boot:
    method: u-boot
    commands: []
    timeout:
      minutes: 2

- test:
    timeout:
      minutes: {{ timeouts.test }}
    interactive:
    - name: backup
      prompts: ['{{ uboot_prompt }}']
      script:
      - command: null
        name: wait-prompt

      - command: "setenv ipaddr {{ ipaddr }}; setenv serverip {{ serverip }}; sf probe"
        name: setup
        successes:
        - message: "SF: Detected"
        failures:
        - message: "SF: Unrecognized"
          exception: JobError
          error: "SPI flash not detected"
        - message: "No SPI flash selected"
          exception: JobError
          error: "sf probe failed"

      - command: "sf read 0x10000000 {{ partitions.kernel.offset }} {{ partitions.kernel.size }}"
        name: read-kernel
        failures:
        - message: "Read: ERROR"
          exception: JobError
          error: "Failed to read kernel partition from flash"

      - command: "tftpput 0x10000000 {{ partitions.kernel.size }} tftp/{{ device_type }}-backup/image.ub"
        name: upload-kernel
        wait_for_prompt: false
        successes:
        - message: "Bytes transferred"
        failures:
        - message: "TFTP error"
          exception: JobError
          error: "Failed to upload kernel via TFTP PUT"
        - message: "Permission denied"
          exception: JobError
          error: "TFTP server write denied"
        - message: "Access violation"
          exception: JobError
          error: "TFTP server write access violation"

      - command: null
        name: wait-after-upload-kernel

      - command: "sf read 0x10000000 {{ partitions.rootfs.offset }} {{ partitions.rootfs.read }}"
        name: read-rootfs
        failures:
        - message: "Read: ERROR"
          exception: JobError
          error: "Failed to read rootfs partition from flash"

      - command: "tftpput 0x10000000 {{ partitions.rootfs.read }} tftp/{{ device_type }}-backup/rootfs.jffs2"
        name: upload-rootfs
        wait_for_prompt: false
        successes:
        - message: "Bytes transferred"
        failures:
        - message: "TFTP error"
          exception: JobError
          error: "Failed to upload rootfs via TFTP PUT"
        - message: "Permission denied"
          exception: JobError
          error: "TFTP server write denied"
        - message: "Access violation"
          exception: JobError
          error: "TFTP server write access violation"

      - command: null
        name: wait-after-upload-rootfs
