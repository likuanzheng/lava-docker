device_type: {{ device_type }}
job_name: {{ name }} boot test
{% if tags %}tags:
{% for t in tags %}  - {{ t }}
{% endfor %}{% endif %}
timeouts:
  job:
    minutes: {{ timeouts.job }}
  action:
    minutes: {{ timeouts.action }}

priority: medium
visibility: public

actions:
- boot:
    method: minimal
    prompts:
      - '{{ boot_prompt }}'
    timeout:
      minutes: {{ timeouts.action }}

- test:
    timeout:
      minutes: {{ timeouts.test }}
